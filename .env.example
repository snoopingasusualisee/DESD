# Django Settings
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database Configuration
# Options: postgresql, mysql, or leave blank for sqlite3
DATABASE_ENGINE=postgresql
DATABASE_NAME=brfn_db
DATABASE_USER=brfn_user
DATABASE_PASSWORD=brfn_pass
DATABASE_HOST=localhost
DATABASE_PORT=5432

# Stripe (test mode)
STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
STRIPE_SECRET_KEY=sk_test_your_key_here

# Email Configuration
# Leave EMAIL_BACKEND blank or unset for console output (development) — emails
# print to your terminal instead of being sent. This is the default and intentional
# for dev so you don't accidentally email real customers from a test database.
#
# Set EMAIL_BACKEND=smtp to send real emails. Defaults below assume Gmail.
# IMPORTANT: For Gmail you MUST use an App Password, NOT your account password.
# Generate one at https://myaccount.google.com/apppasswords (requires 2FA on the account).
# Regular passwords will fail with SMTPAuthenticationError.
EMAIL_BACKEND=
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_TIMEOUT=20
EMAIL_HOST_USER=your-gmail@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password
# Leave DEFAULT_FROM_EMAIL blank for Gmail unless you have verified a custom
# "Send mail as" alias in that Gmail account.
DEFAULT_FROM_EMAIL=your-gmail@gmail.com